# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Calendly — set to true when ready to show the scheduling embed
# NEXT_PUBLIC_CALENDLY_ENABLED=true
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/tuna-keningfordpartners/30min

# Where career applications are delivered (default: info@keningfordpartners.com)
CAREERS_APPLICATION_TO=info@keningfordpartners.com

# Sender — use a verified domain in production, e.g.:
# CAREERS_FROM_EMAIL=Keningford Partners <careers@keningfordpartners.com>
# For Resend testing without a domain, onboarding@resend.dev only delivers to your Resend account email.
CAREERS_FROM_EMAIL=Keningford Careers <onboarding@resend.dev>
